{
  "roles": {
    "name": "default",
    "logicalName": "Fallback Default",
    "subRoles": {
      "default": {
        "logicalName": "Fallback Default",
        "permissions": {
          "tables": ["products"]
        }
      }
    },
    "errors": {
      "profileNotConfigured": "pages.products.profileNotConfigured"
    }
  },
  "templates": {},
  "ui": {
    "resolutionUpscaling": 1440,
    "tables": {
      "products": {
        "style": {
          "maxTableHeight": 700,
          "lengths": {
            "detail": 40,
            "minTable": 30,
            "maxTable": 45
          }
        },
        "pagination": {
          "enabled": true,
          "defaultRowsPerPage": 10,
          "rowsPerPageOptions": [10, 25, 50, 100]
        },
        "bulkRules": {
          "preventMixedStatus": true
        },
        "columns": [
          { "id": "gtinCode", "labelKey": "tables.products.columns.gtinCode" },
          { "id": "productCode", "labelKey": "tables.products.columns.productCode" },
          { "id": "category", "labelKey": "tables.products.columns.category" },
          { "id": "status", "labelKey": "tables.products.columns.status" },
          { "id": "batchName", "labelKey": "tables.products.columns.batchName" }
        ],
        "filters": [
          {
            "id": "category",
            "type": "select",
            "labelKey": "tables.products.filters.category"
          },
          {
            "id": "status",
            "type": "select",
            "labelKey": "tables.products.filters.status"
          },
          {
            "id": "gtinCode",
            "type": "text",
            "labelKey": "tables.products.filters.gtinCode",
            "regEx": "^[a-zA-Z0-9]{1,14}$",
            "message": "tables.products.filters.errors",
            "inputProps": { "maxLength": 14 }
          },
          {
            "id": "productFileId",
            "type": "select",
            "labelKey": "tables.products.filters.productFileId"
          }
        ],
        "detail": {
          "fields": [
            { "id": "gtinCode" },
            { "id": "productCode" },
            { "id": "brand" },
            { "id": "model" },
            { "id": "status" }
          ]
        }
      }
    }
  }
}
