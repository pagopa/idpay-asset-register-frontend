{
  "roles": {
    "name": "default",
    "logicalName": "Fallback Default",
    "subRoles": {
      "default": {
        "logicalName": "Fallback Default",
        "permissions": {
          "tables": ["products"]
        }
      }
    },
    "errors": {
      "profileNotConfigured": "pages.products.profileNotConfigured"
    }
  },
  "templates": {},
  "ui": {
    "backgroundColor": "#FFFFFF",
    "resolutionUpscaling": 1440,
    "tables": {
      "products": {
        "style": {
          "maxTableHeight": 700,
          "lengths": {
            "detail": 40,
            "minTable": 30,
            "maxTable": 45
          },
          "header": {
            "textColor": "#17324D"
          },
          "row": {
            "backgroundColor": "#FFFFFF",
            "hoverBackgroundColor": "#F5F7FA",
            "borderColor": "#E3E7EB",
            "borderWidth": "1px"
          }
        },
        "columns": [
          { "id": "gtinCode", "labelKey": "tables.products.columns.gtinCode" },
          { "id": "productCode", "labelKey": "tables.products.columns.productCode" },
          { "id": "category", "labelKey": "tables.products.columns.category" },
          { "id": "status", "labelKey": "tables.products.columns.status" },
          { "id": "batchName", "labelKey": "tables.products.columns.batchName" }
        ],
        "defaultSort": { "field": "gtinCode", "direction": "asc" },
        "filters": [
          { "id": "category", "type": "select" },
          { "id": "status", "type": "select" },
          { "id": "gtinCode", "type": "text" },
          { "id": "productCode", "type": "text" }
        ],
        "ui": {
          "filtering": { "enabled": true },
          "pagination": { "enabled": true }
        },
        "detail": {
          "fields": [
            { "id": "gtinCode" },
            { "id": "productCode" },
            { "id": "brand" },
            { "id": "model" },
            { "id": "status" }
          ]
        }
      }
    }
  }
}
