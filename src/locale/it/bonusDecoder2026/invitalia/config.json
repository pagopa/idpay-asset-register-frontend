{
  "roles": {
    "name": "invitalia",
    "logicalName": "L1",
    "subRoles": {
      "invitalia": {
        "logicalName": "L1",
        "permissions": {
          "tables": ["products"]
        }
      },
      "invitalia_admin": {
        "logicalName": "L2",
        "permissions": {
          "tables": ["products"]
        }
      }
    }
  },
  "templates": {
    "formats": {
      "csv": {
        "headers": ["Codice GTIN/EAN", "Codice Prodotto", "Categoria", "Marca", "Modello"],
        "fields": ["GTIN123ABC4567", "SKU98765", "{{category}}", "MarcaEsempio", "ModelloX100"]
      }
    },
    "categories": {
      "satellite": { "format": "csv", "name": "satellitare" },
      "terrestrial": { "format": "csv", "name": "terrestre" },
      "terrestrial_via_cable": { "format": "csv", "name": "terrestre-via-cavo" },
      "terrestrial_and_satellite": { "format": "csv", "name": "terrestre-e-satellitare" },
      "terrestrial_satellite_and_via_cable": {
        "format": "csv",
        "name": "terrestre-satellitare-e-via-cavo"
      }
    }
  },
  "ui": {
    "tables": {
      "products": {
        "selection": {
          "enabled": true,
          "rules": {
            "invitalia": ["UPLOADED", "SUPERVISED"],
            "invitalia_admin": ["WAIT_APPROVED"]
          }
        },
        "columns": [
          {
            "id": "select",
            "labelKey": "",
            "type": "checkbox",
            "sortable": false,
            "align": "left"
          },
          {
            "id": "category",
            "labelKey": "pages.products.listHeader.category",
            "sortable": true,
            "align": "left"
          },
          {
            "id": "organizationName",
            "labelKey": "pages.products.listHeader.producer",
            "type": "derived",
            "sortable": false,
            "align": "left"
          },
          {
            "id": "gtinCode",
            "labelKey": "pages.products.listHeader.gtinCode",
            "sortable": true,
            "align": "left"
          },
          {
            "id": "batchName",
            "labelKey": "pages.products.listHeader.batch",
            "sortable": true,
            "align": "left"
          },
          {
            "id": "status",
            "labelKey": "pages.products.listHeader.status",
            "sortable": true,
            "align": "left"
          },
          {
            "id": "actions",
            "labelKey": "",
            "type": "action",
            "sortable": false,
            "align": "left"
          }
        ],
        "filters": [
          {
            "id": "status",
            "type": "select",
            "labelKey": "pages.products.filterLabels.status"
          },
          {
            "id": "producer",
            "type": "select",
            "labelKey": "pages.products.filterLabels.producer"
          },
          {
            "id": "batch",
            "type": "select",
            "labelKey": "pages.products.filterLabels.batch"
          },
          {
            "id": "category",
            "type": "select",
            "labelKey": "pages.products.filterLabels.category"
          },
          {
            "id": "gtinCode",
            "type": "text",
            "labelKey": "pages.products.filterLabels.gtinCode"
          }
        ],
        "ui": {
          "filtering": { "enabled": true },
          "pagination": {
            "enabled": true,
            "defaultRowsPerPage": 10,
            "rowsPerPageOptions": [10, 25, 50, 100]
          }
        },
        "detail": {
          "fields": [
            { "id": "productName", "labelKey": "pages.productDetail.productName" },
            { "id": "batchName", "labelKey": "pages.productDetail.batchName" },
            { "id": "gtinCode", "labelKey": "pages.productDetail.gtinCode" },
            { "id": "productCode", "labelKey": "pages.productDetail.productCode" },
            { "id": "category", "labelKey": "pages.productDetail.category" },
            { "id": "brand", "labelKey": "pages.productDetail.brand" },
            { "id": "model", "labelKey": "pages.productDetail.model" }
          ]
        }
      }
    }
  }
}
