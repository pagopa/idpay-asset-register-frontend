{
  "roles": {
    "name": "invitalia",
    "logicalName": "L1",
    "subRoles": {
      "invitalia": {
        "logicalName": "L1",
        "permissions": {
          "tables": [
            "products"
          ]
        }
      },
      "invitalia_admin": {
        "logicalName": "L2",
        "permissions": {
          "tables": [
            "products"
          ]
        }
      }
    }
  },
  "status": {
    "UPLOADED": {
      "label": "status.products.UPLOADED",
      "color": "default"
    },
    "WAIT_APPROVED": {
      "label": "status.products.WAIT_APPROVED",
      "color": "info"
    },
    "SUPERVISED": {
      "label": "status.products.SUPERVISED",
      "color": "primary"
    },
    "APPROVED": {
      "label": "status.products.APPROVED",
      "color": "success"
    },
    "REJECTED": {
      "label": "status.products.REJECTED",
      "color": "error"
    }
  },
  "ui": {
    "tables": {
      "products": {
        "selection": {
          "enabled": true,
          "rules": {
            "invitalia": [
              "UPLOADED",
              "SUPERVISED"
            ],
            "invitalia_admin": [
              "WAIT_APPROVED"
            ]
          }
        },
        "columns": [
          {
            "id": "select",
            "labelKey": "",
            "type": "checkbox",
            "sortable": false,
            "align": "left"
          },
          {
            "id": "category",
            "labelKey": "pages.products.listHeader.category",
            "sortable": true,
            "align": "left"
          },
          {
            "id": "organizationName",
            "labelKey": "pages.products.listHeader.producer",
            "type": "derived",
            "sortable": false,
            "align": "left"
          },
          {
            "id": "gtinCode",
            "labelKey": "pages.products.listHeader.gtinCode",
            "sortable": true,
            "align": "left"
          },
          {
            "id": "batchName",
            "labelKey": "pages.products.listHeader.batch",
            "sortable": true,
            "align": "left"
          },
          {
            "id": "status",
            "labelKey": "pages.products.listHeader.status",
            "sortable": true,
            "align": "left"
          },
          {
            "id": "actions",
            "labelKey": "",
            "type": "action",
            "sortable": false,
            "align": "left"
          }
        ],
        "filters": [
          {
            "id": "status",
            "type": "select",
            "labelKey": "tables.products.filters.status",
