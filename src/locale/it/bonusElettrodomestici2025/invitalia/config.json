      "cookinghobs": {
        "label": "category.cookinghobs.label",
        "format": "csv",
        "name": "cookinghobs"
      }
    },
    "status": {
      "UPLOADED": {
        "label": "status.products.UPLOADED",
        "color": "default"
      },
      "WAIT_APPROVED": {
        "label": "status.products.WAIT_APPROVED",
        "color": "info"
      },
      "SUPERVISED": {
        "label": "status.products.SUPERVISED",
        "color": "primary"
      },
      "APPROVED": {
        "label": "status.products.APPROVED",
        "color": "success"
      },
      "REJECTED": {
        "label": "status.products.REJECTED",
        "color": "error"
      }
    }
  },
  "ui": {
    "tables": {
      "products": {
        "selection": {
          "enabled": true,
          "rules": {
            "invitalia": [
              "UPLOADED",
              "SUPERVISED"
            ],
            "invitalia_admin": [
              "WAIT_APPROVED"
            ]
          }
        },
        "columns": [
          {
            "id": "select",
            "labelKey": "",
            "type": "checkbox",
            "sortable": false,
            "align": "left"
          },
          {
            "id": "category",
            "labelKey": "pages.products.listHeader.category",
            "sortable": true,
            "align": "left"
          },
          {
            "id": "organizationName",
            "labelKey": "pages.products.listHeader.producer",
            "type": "derived",
            "sortable": false,
            "align": "left"
          },
          {
            "id": "eprelCode",
            "labelKey": "pages.products.listHeader.eprelCode",
            "type": "eprelLink",
            "sortable": true,
            "align": "left"
          },
          {
            "id": "gtinCode",
            "labelKey": "pages.products.listHeader.gtinCode",
            "sortable": true,
            "align": "left"
          },
          {
            "id": "productFileId",
            "labelKey": "pages.products.listHeader.productFileId",
            "sortable": true,
            "align": "left"
          },
          {
            "id": "status",
            "labelKey": "pages.products.listHeader.status",
            "sortable": true,
            "align": "left"
          },
          {
            "id": "actions",
            "labelKey": "",
            "type": "action",
            "sortable": false,
            "align": "left"
          }
        ],
        "defaultSort": {
          "field": "category",
          "direction": "asc"
        },
        "filters": [
          {
            "id": "status",
            "type": "select",
            "labelKey": "tables.products.filters.status",
            "defaultValue": "WAIT_APPROVED"
          },
          {
            "id": "producer",
            "type": "select",
            "labelKey": "pages.products.filterLabels.producer"
          },
          {
            "id": "productFileId",
            "type": "select",
            "labelKey": "tables.products.filters.productFileId"
          },
          {
            "id": "category",
            "type": "select",
            "labelKey": "tables.products.filters.category"
          },
          {
            "id": "eprelCode",
            "type": "text",
            "labelKey": "tables.products.filters.eprelCode",
            "regEx": "^\\d{5}$",
            "message": "tables.products.filters.errors.eprelCode",
            "inputProps": {"inputMode": "numeric", "pattern": "[0-9]*"}
          },
          {
            "id": "gtinCode",
            "type": "text",
            "labelKey": "tables.products.filters.gtinCode",
            "regEx": "^[a-zA-Z0-9]{1,14}$",
            "message": "tables.products.filters.errors.gtinCode",
            "inputProps": { "maxLength": 14 }
          }
        ],
        "ui": {
          "filtering": {
            "enabled": true
          },
          "pagination": {
            "enabled": true,
            "defaultRowsPerPage": 10,
            "rowsPerPageOptions": [
              10,
              25,
              50,
              100
            ]
          }
        },
        "detail": {
          "fields": [
            {
              "id": "productName",
              "labelKey": "pages.productDetail.productName"
            },
            {
              "id": "productFileId",
              "labelKey": "pages.productDetail.productFileId"
            },
            {
              "id": "registrationDate",
              "labelKey": "pages.productDetail.eprelCheckDate"
            },
            {
              "id": "eprelCode",
              "labelKey": "pages.productDetail.eprelCode"
            },
            {
              "id": "gtinCode",
              "labelKey": "pages.productDetail.gtinCode"
            },
            {
              "id": "productCode",
              "labelKey": "pages.productDetail.productCode"
            },
            {
              "id": "category",
              "labelKey": "pages.productDetail.category"
            },
            {
              "id": "brand",
              "labelKey": "pages.productDetail.brand"
            },
            {
              "id": "model",
              "labelKey": "pages.productDetail.model"
            },
            {
              "id": "energyClass",
              "labelKey": "pages.productDetail.energyClass"
            },
            {
              "id": "countryOfProduction",
              "labelKey": "pages.productDetail.countryOfProduction"
            },
            {
              "id": "capacity",
              "labelKey": "pages.productDetail.capacity"
            }
          ]
        }
      }
    }
  }
