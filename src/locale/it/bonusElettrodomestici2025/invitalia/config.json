{
  "roles": {
    "name": "invitalia",
    "logicalName": "L1",
    "subRoles": {
      "invitalia": {
        "logicalName": "L1",
        "permissions": {
          "tables": ["products"]
        }
      },
      "invitalia_admin": {
        "logicalName": "L2",
        "permissions": {
          "tables": ["products"]
        }
      }
    }
  },
  "templates": {},
  "ui": {
    "tables": {
      "products": {
        "selection": {
          "enabled": true,
          "rules": {
            "invitalia": ["UPLOADED", "SUPERVISED"],
            "invitalia_admin": ["WAIT_APPROVED"]
          }
        },
        "columns": [
          {
            "id": "select",
            "labelKey": "",
            "type": "checkbox",
            "sortable": false,
            "align": "left"
          },
          {
            "id": "category",
            "labelKey": "pages.products.listHeader.category",
            "sortable": true,
            "align": "left"
          },
          {
            "id": "organizationName",
            "labelKey": "pages.products.listHeader.producer",
            "type": "derived",
            "sortable": false,
            "align": "left"
          },
          {
            "id": "eprelCode",
            "labelKey": "pages.products.listHeader.eprelCode",
            "type": "eprelLink",
            "sortable": true,
            "align": "center"
          },
          {
            "id": "gtinCode",
            "labelKey": "pages.products.listHeader.gtinCode",
            "sortable": true,
            "align": "center"
          },
          {
            "id": "batchName",
            "labelKey": "pages.products.listHeader.batch",
            "sortable": true,
            "align": "left"
          },
          {
            "id": "status",
            "labelKey": "pages.products.listHeader.status",
            "sortable": true,
            "align": "left"
          },
          {
            "id": "actions",
            "labelKey": "",
            "type": "action",
            "sortable": false,
            "align": "left"
          }
        ],
        "filters": [
          {
            "id": "status",
            "type": "select",
            "labelKey": "pages.products.filterLabels.status",
            "defaultValue": "WAIT_APPROVED"
          },
          {
            "id": "producer",
            "type": "select",
            "labelKey": "pages.products.filterLabels.producer"
          },
          {
            "id": "batch",
            "type": "select",
            "labelKey": "pages.products.filterLabels.batch"
          },
          {
            "id": "category",
            "type": "select",
            "labelKey": "pages.products.filterLabels.category"
          },
          {
            "id": "gtinCode",
            "type": "text",
            "labelKey": "pages.products.filterLabels.gtinCode"
          }
        ],
        "detail": {
          "fields": [
            { "id": "productName", "labelKey": "pages.productDetail.productName" },
            { "id": "batchName", "labelKey": "pages.productDetail.batchName" },
            { "id": "registrationDate", "labelKey": "pages.productDetail.eprelCheckDate" },
            { "id": "eprelCode", "labelKey": "pages.productDetail.eprelCode" },
            { "id": "gtinCode", "labelKey": "pages.productDetail.gtinCode" },
            { "id": "productCode", "labelKey": "pages.productDetail.productCode" },
            { "id": "category", "labelKey": "pages.productDetail.category" },
            { "id": "brand", "labelKey": "pages.productDetail.brand" },
            { "id": "model", "labelKey": "pages.productDetail.model" },
            { "id": "energyClass", "labelKey": "pages.productDetail.energyClass" },
            {
              "id": "countryOfProduction",
              "labelKey": "pages.productDetail.countryOfProduction"
            },
            { "id": "capacity", "labelKey": "pages.productDetail.capacity" }
          ]
        }
