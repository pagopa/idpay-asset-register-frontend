{
  "roles": {
    "name": "invitalia",
    "logicalName": "L1",
    "subRoles": {
      "invitalia": {
        "logicalName": "L1",
        "permissions": {
          "tables": [
            "products"
          ]
        }
      },
      "invitalia_admin": {
        "logicalName": "L2",
        "permissions": {
          "tables": [
            "products"
          ]
        }
      }
    }
  },
  "status": {
    "UPLOADED": {
      "label": "status.products.UPLOADED",
      "color": "default"
    },
    "WAIT_APPROVED": {
      "label": "status.products.WAIT_APPROVED",
      "color": "info"
    },
    "SUPERVISED": {
      "label": "status.products.SUPERVISED",
      "color": "primary"
    },
    "APPROVED": {
      "label": "status.products.APPROVED",
      "color": "success"
    },
    "REJECTED": {
      "label": "status.products.REJECTED",
      "color": "error"
    }
  },
  "ui": {
    "tables": {
      "products": {
        "selection": {
          "enabled": true,
          "rules": {
            "invitalia": [
