{
  "roles": {
    "name": "invitalia",
    "logicalName": "L1",
    "subRoles": {
      "invitalia": {
        "logicalName": "L1",
        "permissions": {
          "tables": ["products"]
        }
      },
      "invitalia_admin": {
        "logicalName": "L2",
        "permissions": {
          "tables": ["products"]
        }
      }
    }
  },
  "templates": {},
  "ui": {
    "tables": {
      "products": {
        "selection": {
          "enabled": true,
          "rules": {
            "invitalia": ["UPLOADED", "SUPERVISED"],
            "invitalia_admin": ["WAIT_APPROVED"]
          }
        },
        "columns": [
          {
            "id": "select",
            "labelKey": "",
            "type": "checkbox",
            "sortable": false,
            "align": "left"
          },
          {
            "id": "category",
            "labelKey": "pages.products.listHeader.category",
            "sortable": true,
            "align": "left"
          },
          {
            "id": "organizationName",
            "labelKey": "pages.products.listHeader.producer",
            "type": "derived",
            "sortable": false,
            "align": "left"
          },
          {
            "id": "eprelCode",
            "labelKey": "pages.products.listHeader.eprelCode",
            "type": "eprelLink",
            "sortable": true,
            "align": "left"
          },
          {
            "id": "gtinCode",
            "labelKey": "pages.products.listHeader.gtinCode",
            "sortable": true,
            "align": "left"
          },
          {
            "id": "batchName",
            "labelKey": "pages.products.listHeader.batch",
            "sortable": true,
            "align": "left"
          },
          {
            "id": "status",
            "labelKey": "pages.products.listHeader.status",
            "sortable": true,
            "align": "left"
          },
          { "id": "actions", "labelKey": "", "type": "action", "sortable": false, "align": "left" }
        ],
        "defaultSort": { "field": "category", "direction": "asc" },
        "ui": {
          "filtering": { "enabled": true },
          "pagination": {
            "enabled": true,
            "defaultRowsPerPage": 10,
            "rowsPerPageOptions": [10, 25, 50, 100]
          }
        }
      }
    }
  }
}
