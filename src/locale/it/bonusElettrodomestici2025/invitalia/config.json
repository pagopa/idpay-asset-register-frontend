            "products"
          ]
        }
      },
      "invitalia_admin": {
        "logicalName": "L2",
        "permissions": {
          "tables": [
            "products"
          ]
        }
      }
    }
  },
  "templates": {
    "category": {
      "washingmachines": {
        "label": "category.washingmachines.label",
        "format": "eprel",
        "name": "eprel"
      },
      "tumbledryers": {
        "label": "category.tumbledryers.label",
        "format": "eprel",
        "name": "eprel"
      },
      "ovens": {
        "label": "category.ovens.label",
        "format": "eprel",
        "name": "eprel"
      },
      "rangehoods": {
        "label": "category.rangehoods.label",
        "format": "eprel",
        "name": "eprel"
      },
      "dishwashers": {
        "label": "category.dishwashers.label",
        "format": "eprel",
        "name": "eprel"
      },
      "washerdriers": {
        "label": "category.washerdriers.label",
        "format": "eprel",
        "name": "eprel"
      },
      "refrigeratingappl": {
        "label": "category.refrigeratingappl.label",
        "format": "eprel",
        "name": "eprel"
