      },
      "invitalia_admin": {
        "logicalName": "L2",
        "permissions": {
          "tables": [
            "products"
          ]
        }
      }
    }
  },
  "templates": {
    "category": {
      "washingmachines": {
        "label": "category.washingmachines.label",
