              "SUPERVISED"
            ],
            "invitalia_admin": [
              "WAIT_APPROVED"
            ]
          }
        },
        "columns": [
          {
            "id": "select",
            "labelKey": "",
            "type": "checkbox",
            "sortable": false,
            "align": "left"
          },
          {
            "id": "category",
            "labelKey": "pages.products.listHeader.category",
            "sortable": true,
            "align": "left"
          },
          {
            "id": "organizationName",
            "labelKey": "pages.products.listHeader.producer",
            "type": "derived",
            "sortable": false,
            "align": "left"
          },
          {
            "id": "eprelCode",
            "labelKey": "pages.products.listHeader.eprelCode",
