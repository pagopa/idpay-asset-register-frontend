{
  "roles": {
    "name": "default",
    "logicalName": "Utente Standard",
    "subRoles": {
      "default": {
        "logicalName": "Utente Standard",
        "permissions": {
          "tables": ["products"]
        }
      }
    },
    "errors": {
      "profileNotConfigured": "pages.products.profileNotConfigured"
    }
  },
  "categories": {
    "WASHINGMACHINES": {
      "labelKey": "categories.lavatrice",
      "templateFormat": "eprel",
      "enabledIn": { "upload": true, "filters": true }
    },
    "WASHERDRIERS": {
      "labelKey": "categories.lavasciuga",
      "templateFormat": "eprel",
      "enabledIn": { "upload": true, "filters": true }
    },
    "OVENS": {
      "labelKey": "categories.forno",
      "templateFormat": "eprel",
      "enabledIn": { "upload": true, "filters": true }
    },
    "RANGEHOODS": {
      "labelKey": "categories.cappa",
      "templateFormat": "eprel",
      "enabledIn": { "upload": true, "filters": true }
    },
    "DISHWASHERS": {
      "labelKey": "categories.lavastoviglie",
      "templateFormat": "eprel",
      "enabledIn": { "upload": true, "filters": true }
    },
    "TUMBLEDRYERS": {
      "labelKey": "categories.asciugatrice",
      "templateFormat": "eprel",
      "enabledIn": { "upload": true, "filters": true }
    },
    "REFRIGERATINGAPPL": {
      "labelKey": "categories.refrigerazione",
      "templateFormat": "eprel",
      "enabledIn": { "upload": true, "filters": true }
    },
    "COOKINGHOBS": {
      "labelKey": "categories.pianoCottura",
      "templateFormat": "csv",
      "enabledIn": { "upload": true, "filters": true }
    }
  },
  "templates": {
    "formats": {
      "csv": {
        "headers": [
          "Codice GTIN/EAN",
          "Codice Prodotto",
          "Categoria",
          "Paese di Produzione",
          "Marca",
          "Modello"
        ],
        "fields": [
          "GTIN123ABC4567",
          "SKU98765",
          "Piano cottura",
          "IT",
          "MarcaEsempio",
          "ModelloX100"
        ]
      },
      "eprel": {
        "headers": [
          "Codice EPREL",
          "Codice GTIN/EAN",
          "Codice Prodotto",
          "Categoria",
          "Paese di Produzione"
        ],
        "fields": ["12345", "GTIN01234", "SKU12345", "Lavatrice", "IT"]
      }
    },
    "categories": {
      "washingmachines": { "format": "eprel", "name": "eprel" },
      "tumbledryers": { "format": "eprel", "name": "eprel" },
      "ovens": { "format": "eprel", "name": "eprel" },
      "rangehoods": { "format": "eprel", "name": "eprel" },
      "dishwashers": { "format": "eprel", "name": "eprel" },
      "washerdriers": { "format": "eprel", "name": "eprel" },
      "refrigeratingappl": { "format": "eprel", "name": "eprel" },
      "cookinghobs": { "format": "csv", "name": "cookinghobs" }
    }
  },
  "ui": {
    "tables": {
      "products": {
        "bulkRules": {
          "preventMixedStatus": true
        },
        "columns": [
          { "id": "category", "labelKey": "tables.products.columns.category", "sortable": true },
          {
            "id": "energyClass",
            "labelKey": "tables.products.columns.energyClass",
            "sortable": true
          },
          { "id": "eprelCode", "labelKey": "tables.products.columns.eprelCode", "sortable": true },
          { "id": "gtinCode", "labelKey": "tables.products.columns.gtinCode", "sortable": true },
          { "id": "batchName", "labelKey": "tables.products.columns.batchName", "sortable": false },
          { "id": "status", "labelKey": "tables.products.columns.status", "sortable": true }
        ],
        "filters": [
          {
            "id": "status",
            "type": "select",
            "labelKey": "tables.products.filters.status"
          },
          {
            "id": "productFileId",
            "type": "select",
            "labelKey": "tables.products.filters.productFileId"
          },
          {
            "id": "category",
            "type": "select",
            "labelKey": "tables.products.filters.category",
            "useInitiativeCategories": true
          },
          {
            "id": "gtinCode",
            "type": "text",
            "labelKey": "tables.products.filters.gtinCode",
            "regEx": "^[a-zA-Z0-9]{1,14}$",
            "message": "tables.products.filters.errors.gtinCode",
            "inputProps": { "maxLength": 14 }
          },
          {
            "id": "productCode",
            "type": "text",
            "labelKey": "tables.products.filters.productCode"
          }
        ],
        "detail": {
          "fields": [
            { "id": "productName", "labelKey": "pages.productDetail.productName" },
            { "id": "batchName", "labelKey": "pages.productDetail.batchName" },
            { "id": "gtinCode", "labelKey": "pages.productDetail.gtinCode" },
            { "id": "productCode", "labelKey": "pages.productDetail.productCode" },
            { "id": "brand", "labelKey": "pages.productDetail.brand" },
            { "id": "model", "labelKey": "pages.productDetail.model" },
            { "id": "status", "labelKey": "pages.productDetail.status" }
          ]
        }
      }
    }
  }
}
