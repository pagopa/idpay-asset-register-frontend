{
  "roles": {
    "name": "operatore",
    "logicalName": "Produttore",
    "subRoles": {
      "operatore": {
        "logicalName": "Produttore",
        "permissions": {
          "tables": [
            "products"
          ]
        }
      }
    }
  },
  "templates": {
    "formats": {
      "csv": {
        "headers": [
          "Codice GTIN/EAN",
          "Codice Prodotto",
          "Categoria",
          "Marca",
          "Modello"
        ],
        "fields": [
          "GTIN123ABC4567",
          "SKU98765",
          "{{category}}",
          "MarcaEsempio",
          "ModelloX100"
        ]
      },
      "eprel": {
        "headers": [
          "Codice EPREL",
          "Codice GTIN/EAN",
          "Codice Prodotto",
          "Categoria",
          "Paese di Produzione"
        ],
        "fields": [
          "12345",
          "GTIN01234",
          "SKU12345",
          "Lavatrice",
          "IT"
        ]
      }
    },
    "category": {
      "washingmachines": {
        "label": "category.washingmachines.label",
        "format": "eprel",
        "name": "eprel"
      },
      "tumbledryers": {
        "label": "category.tumbledryers.label",
        "format": "eprel",
        "name": "eprel"
      },
      "ovens": {
        "label": "category.ovens.label",
        "format": "eprel",
        "name": "eprel"
      },
      "rangehoods": {
        "label": "category.rangehoods.label",
        "format": "eprel",
        "name": "eprel"
      },
      "dishwashers": {
        "label": "category.dishwashers.label",
        "format": "eprel",
        "name": "eprel"
      },
      "washerdriers": {
        "label": "category.washerdriers.label",
        "format": "eprel",
        "name": "eprel"
      },
      "refrigeratingappl": {
        "label": "category.refrigeratingappl.label",
        "format": "eprel",
        "name": "eprel"
      },
      "cookinghobs": {
        "label": "category.cookinghobs.label",
        "format": "csv",
        "name": "cookinghobs"
      }
    },
    "status": {
      "UPLOADED": {
        "label": "status.products.UPLOADED",
        "color": "default"
      },
      "APPROVED": {
        "label": "status.products.APPROVED",
        "color": "success"
      },
      "REJECTED": {
        "label": "status.products.REJECTED",
        "color": "error"
      }
    }
  },
  "ui": {
    "tables": {
      "products": {
        "columns": [
          {
            "id": "category",
            "labelKey": "tables.products.columns.category",
            "sortable": true,
            "align": "center"
          },
          {
            "id": "energyClass",
            "labelKey": "tables.products.columns.energyClass",
            "sortable": true,
            "align": "center"
          },
          {
            "id": "eprelCode",
            "labelKey": "tables.products.columns.eprelCode",
            "type": "eprelLink",
            "sortable": true,
            "align": "center"
          },
          {
            "id": "gtinCode",
            "labelKey": "tables.products.columns.gtinCode",
            "sortable": true,
            "align": "center"
          },
          {
            "id": "productFileId",
            "labelKey": "tables.products.columns.productFileId",
            "sortable": false,
            "align": "left"
          },
          {
            "id": "status",
            "labelKey": "tables.products.columns.status",
            "sortable": true,
            "align": "left"
          }
        ],
        "defaultSort": {
          "field": "gtinCode",
          "direction": "asc"
        },
        "filters": [
          {
            "id": "status",
            "type": "select",
            "labelKey": "tables.products.filters.status"
          },
          {
            "id": "productFileId",
            "type": "select",
            "labelKey": "tables.products.filters.productFileId"
          },
          {
            "id": "category",
            "type": "select",
            "labelKey": "tables.products.filters.category"
          },
          {
            "id": "eprelCode",
            "type": "text",
            "labelKey": "tables.products.filters.eprelCode",
            "regEx": "^\/d+$",
            "error": "tables.products.filters.errors.eprelCode"
          },
          {
            "id": "gtinCode",
            "type": "text",
            "labelKey": "tables.products.filters.gtinCode",
            "regEx": "^[a-zA-Z0-9]{1,14}$",
            "error": "tables.products.filters.errors.gtinCode"
          }
        ],
        "ui": {
          "filtering": {
            "enabled": true
          },
          "pagination": {
            "enabled": true,
            "defaultRowsPerPage": 10,
            "rowsPerPageOptions": [10, 25, 50, 100]
          }
        },
        "detail": {
          "fields": [
            { "id": "productName", "labelKey": "pages.productDetail.productName" },
            { "id": "batchName", "labelKey": "pages.productDetail.batchName" },
            { "id": "registrationDate", "labelKey": "pages.productDetail.eprelCheckDate" },
            { "id": "eprelCode", "labelKey": "pages.productDetail.eprelCode" },
            { "id": "gtinCode", "labelKey": "pages.productDetail.gtinCode" },
            { "id": "productCode", "labelKey": "pages.productDetail.productCode" },
            { "id": "category", "labelKey": "pages.productDetail.category" },
            { "id": "brand", "labelKey": "pages.productDetail.brand" },
            { "id": "model", "labelKey": "pages.productDetail.model" },
            { "id": "energyClass", "labelKey": "pages.productDetail.energyClass" },
            { "id": "countryOfProduction", "labelKey": "pages.productDetail.countryOfProduction" },
            { "id": "capacity", "labelKey": "pages.productDetail.capacity" }
          ]
        }
      }
    }
  }
}